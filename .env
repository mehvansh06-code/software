# Document folder base paths. Use local folder (same machine) or UNC (e.g. \\192.168.1.70\Import Shipment Documents)
SHIPMENT_DOCS_BASE=./documents/Import Shipment Documents
EXPORT_SHIPMENT_DOCS_BASE=./documents/Export Shipment Documents

# API host: only used outside browser (e.g. SSR). In the app we use the same host you open the page from, so WiFi/IP change does not require updating this.
# VITE_API_HOST=192.168.1.70