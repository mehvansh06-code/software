# Document folder base paths. Use local folder (same machine) or UNC (e.g. \\server\Import Shipment Documents)
SHIPMENT_DOCS_BASE=./documents/Import Shipment Documents
EXPORT_SHIPMENT_DOCS_BASE=./documents/Export Shipment Documents

# JWT secret used to sign auth tokens. Replace with a strong random value for production.
JWT_SECRET=8b2f9e2b3c4d5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0

# API host: only used outside browser (e.g. SSR). In the app we use the same host you open the page from, so WiFi/IP change does not require updating this.
# VITE_API_HOST=192.168.1.70

# Company-sensitive values required for Sales Indent (replace with real values)
# IMPORTANT: do NOT commit your real `.env` to source control. Add `.env` to .gitignore.
GFPL_GSTIN=REPLACE_GFPL_GSTIN
GFPL_IEC=REPLACE_GFPL_IEC
GFPL_BANK_ACCT=REPLACE_GFPL_BANK_ACCT
GFPL_IFSC=REPLACE_GFPL_IFSC
GFPL_SWIFT=REPLACE_GFPL_SWIFT
GTEX_GSTIN=REPLACE_GTEX_GSTIN
GTEX_IEC=REPLACE_GTEX_IEC
GTEX_BANK_ACCT=REPLACE_GTEX_BANK_ACCT
GTEX_IFSC=REPLACE_GTEX_IFSC
GTEX_SWIFT=REPLACE_GTEX_SWIFT